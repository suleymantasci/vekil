generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String    @id @default(uuid())
  name          String
  taxNumber     String?
  address       String?
  phone         String?
  email         String?
  logo          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  buildings     Building[]
  users         User[]
  roles         Role[]
  auditLogs     AuditLog[]
  reservations  Reservation[]
  announcements Announcement[]
  meetings      Meeting[]
  votes         Vote[]
  workOrders    WorkOrder[]
  suppliers     Supplier[]
  purchaseRequests PurchaseRequest[]
}

model Building {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  address        String?
  yearBuilt      Int?
  totalFloors     Int?
  totalApartments Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  apartments     Apartment[]
  assets         Asset[]
  workOrders     WorkOrder[]
  reservations   Reservation[]
  meetings       Meeting[]
  units          Unit[]
  users          User[]
  announcements Announcement[]

}

model Apartment {
  id           String   @id @default(uuid())
  buildingId   String
  unitNumber   String
  floor        Int?
  areaM2       Float?
  shareRatio   Float   @default(1)
  type         String   @default("RESIDENCE") // RESIDENCE, COMMERCIAL
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  building     Building @relation(fields: [buildingId], references: [id])
  users         User[]
  charges       Charge[]
  payments      Payment[]
  workOrders    WorkOrder[]
  reservations  Reservation[]
  meetingAttendances MeetingAttendance[]
  voteParticipants VoteParticipant[]
}

model User {
  id             String   @id @default(uuid())
  organizationId String
  buildingId     String?
  apartmentId    String?
  email          String   @unique
  passwordHash   String
  firstName      String
  lastName       String
  phone          String?
  avatar         String?
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  building       Building?   @relation(fields: [buildingId], references: [id])
  apartment      Apartment?  @relation(fields: [apartmentId], references: [id])
  roles          UserRole[]
  auditLogs      AuditLog[]
  kvkkConsents   KvkkConsent[]
  meetingAttendances MeetingAttendance[]
  voteParticipants VoteParticipant[]
  notifications  Notification[]
  reportedWorkOrders WorkOrder[] @relation("WorkOrderReporter")
  assignedWorkOrders WorkOrder[] @relation("WorkOrderAssignee")
}

model Role {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  permissions    RolePermission[]
  users          UserRole[]
}

model Permission {
  id        String   @id @default(uuid())
  resource  String   // buildings, apartments, charges, payments, users, roles, workorders, assets, whatsapp, reservations, meetings, votes, suppliers
  action    String   // create, read, update, delete, approve
  createdAt DateTime @default(now())

  rolePermissions RolePermission[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model RolePermission {
  id         String     @id @default(uuid())
  roleId     String
  permissionId String
  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  action         String
  resource       String
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
}

model TahakkukRule {
  id             String   @id @default(uuid())
  organizationId String
  buildingId     String
  name           String
  description    String?
  calculationType String  // fixed, area_m2, share_ratio
  amount         Float
  periodStart    DateTime
  periodEnd      DateTime
  dueDate       DateTime
  isActive      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Charge {
  id             String   @id @default(uuid())
  organizationId String
  apartmentId    String
  tahakkukRuleId String
  period         String   // 2024-01, 2024-02
  amount         Float
  status         String   @default("PENDING") // PENDING, PARTIAL, PAID
  dueDate        DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  apartment      Apartment @relation(fields: [apartmentId], references: [id])
  lateFees       LateFee[]
  payments       Payment[]
  invoice        Invoice?
}

model LateFee {
  id         String   @id @default(uuid())
  chargeId   String
  amount     Float
  daysLate   Int
  rate       Float   // daily rate used
  calculatedAt DateTime @default(now())
  dueDate    DateTime
  isPaid     Boolean  @default(false)
  charge     Charge   @relation(fields: [chargeId], references: [id])
}

model Payment {
  id             String   @id @default(uuid())
  organizationId String
  apartmentId    String
  chargeId       String?
  amount         Float
  paymentMethod  String   // BANK_TRANSFER, CREDIT_CARD, CASH
  paidAt         DateTime @default(now())
  description    String?
  referenceNo    String?
  confirmedBy    String?
  createdAt      DateTime @default(now())

  apartment      Apartment @relation(fields: [apartmentId], references: [id])
  charge         Charge?   @relation(fields: [chargeId], references: [id])
}

model Invoice {
  id             String   @id @default(uuid())
  chargeId       String   @unique
  invoiceNo      String   @unique
  amount         Float
  status         String   @default("DRAFT") // DRAFT, SENT, PAID
  sentAt         DateTime?
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  charge         Charge   @relation(fields: [chargeId], references: [id])
}

model Asset {
  id           String   @id @default(uuid())
  buildingId   String
  name         String
  type         String   // elevator, generator, pool, hvac, other
  brand        String?
  model        String?
  serialNo     String?
  location     String?
  warrantyEnd  DateTime?
  installDate DateTime?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  building    Building    @relation(fields: [buildingId], references: [id])
  workOrders  WorkOrder[]
}

model WorkOrder {
  id           String   @id @default(uuid())
  buildingId   String
  assetId      String?
  reportedBy   String
  assignedTo   String?
  title        String
  description  String
  category     String   @default("other") // electrical, plumbing, structural, other
  location     String?
  photos       String[] @default([])
  priority     String   @default("medium") // low, medium, high, urgent
  status       String   @default("open") // open, in_progress, pending, resolved, closed
  resolution   String?
  resolvedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  building    Building    @relation(fields: [buildingId], references: [id])
  asset       Asset?      @relation(fields: [assetId], references: [id])
  reporter    User        @relation("WorkOrderReporter", fields: [reportedBy], references: [id])
  assignee    User?       @relation("WorkOrderAssignee", fields: [assignedTo], references: [id])
  organizationId String
  apartmentId    String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  apartment      Apartment?  @relation(fields: [apartmentId], references: [id])
}

model KvkkConsent {
  id         String   @id @default(uuid())
  userId     String
  channel    String   // whatsapp, email, sms
  purpose    String   // chatbot, marketing, notification
  granted    Boolean
  grantedAt  DateTime @default(now())
  revokedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, channel, purpose])
}

model Reservation {
  id           String   @id @default(uuid())
  organizationId String
  buildingId   String
  apartmentId  String
  facility     String   // pool, court, parking, meeting_room, gym, other
  title        String
  startTime    DateTime
  endTime      DateTime
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  notes        String?
  approvedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  building     Building     @relation(fields: [buildingId], references: [id])
  apartment    Apartment    @relation(fields: [apartmentId], references: [id])
}

model Announcement {
  id             String   @id @default(uuid())
  organizationId String
  buildingId    String?
  title         String
  body          String
  type          String   @default("INFO") // INFO, WARNING, URGENT, EVENT
  isPublished   Boolean  @default(false)
  publishedAt   DateTime?
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  building     Building?    @relation(fields: [buildingId], references: [id])
}

model Meeting {
  id             String   @id @default(uuid())
  organizationId String
  buildingId     String
  title          String
  description    String?
  meetingDate    DateTime
  location       String?
  status         String   @default("DRAFT") // DRAFT, SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  minutes        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization  Organization       @relation(fields: [organizationId], references: [id])
  building      Building           @relation(fields: [buildingId], references: [id])
  attendances   MeetingAttendance[]
  votes         Vote[]
}

model MeetingAttendance {
  id         String   @id @default(uuid())
  meetingId  String
  apartmentId String
  userId     String
  present    Boolean  @default(false)
  voteWeight Float   @default(1) // based on share ratio
  createdAt  DateTime @default(now())

  meeting   Meeting   @relation(fields: [meetingId], references: [id])
  apartment Apartment @relation(fields: [apartmentId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([meetingId, apartmentId])
}

model Vote {
  id         String   @id @default(uuid())
  meetingId  String
  organizationId String
  title      String
  description String?
  voteType   String   @default("OPEN") // OPEN, SECRET, BINDING, CONSULTATIVE
  options    Json    // ["Evet", "Hayır", "Çekimser"]
  status     String   @default("OPEN") // OPEN, CLOSED
  closesAt   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  meeting    Meeting           @relation(fields: [meetingId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])
  participants VoteParticipant[]
}

model VoteParticipant {
  id         String   @id @default(uuid())
  voteId     String
  apartmentId String
  userId     String
  option     String   // voted option
  weight     Float   @default(1)
  createdAt  DateTime @default(now())

  vote      Vote     @relation(fields: [voteId], references: [id])
  apartment Apartment @relation(fields: [apartmentId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([voteId, apartmentId])
}

model Supplier {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  category       String   // construction, cleaning, security, maintenance, other
  rating         Float?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization   Organization       @relation(fields: [organizationId], references: [id])
  purchaseRequests PurchaseRequest[]
}

model PurchaseRequest {
  id             String   @id @default(uuid())
  organizationId String
  supplierId     String?
  buildingId     String
  title          String
  description    String
  category       String   // construction, cleaning, security, maintenance, other
  status         String   @default("DRAFT") // DRAFT, PUBLISHED, RECEIVED, APPROVED, REJECTED, AWARDED, CANCELLED
  estimatedAmount Float?
  awardedAmount  Float?
  deadline       DateTime?
  notes          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])
  supplier       Supplier?    @relation(fields: [supplierId], references: [id])
}

model Notification {
  id     String   @id @default(uuid())
  userId String
  title String
  body  String
  type  String   @default("INFO") // INFO, WARNING, URGENT
  isRead Boolean @default(false)
  data  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Unit {
  id         String   @id @default(uuid())
  buildingId String
  name       String   // "1. Kat", "Bodrum", "Çatı"
  type       String   // floor, basement, roof, parking, storage
  createdAt DateTime @default(now())

  building Building @relation(fields: [buildingId], references: [id])
}

// Stub models for code compilation (relations intentionally minimal)
model Visitor { id String @id @default(uuid()) }
model AccessLog { id String @id @default(uuid()) }
model Meter { id String @id @default(uuid()) }
model MeterReading { id String @id @default(uuid()) }
model Document { id String @id @default(uuid()) }
model IncomeExpense { id String @id @default(uuid()) }
model Budget { id String @id @default(uuid()) }
model PaymentRequest { id String @id @default(uuid()) }
